          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Status code name has string\", function () {\r",
              "    pm.response.to.have.status(\"OK\");\r",
              "});\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type is present\", ()=> {\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "});\r",
              "pm.test(\"Content-Type is application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "    var jsonData = pm.response.json();\r",
              "pm.test(\"Response value is present\", function () {\r",
              "\r",
              "    pm.expect(jsonData.active).to.eql(1);\r",
              "    pm.expect(jsonData.Busy).to.eql(1);\r",
              "    pm.expect(jsonData.testing).to.eql(1);\r",
              "    pm.expect(jsonData[\"5000\"]).to.eql(1);\r",
              "    pm.expect(jsonData[\"6000\"]).to.eql(1);\r",
              "    pm.expect(jsonData[\"0\"]).to.eql(2);\r",
              "});\r",
              "\r",
              "\r",
              "// Parse response JSON\r",
              "\r",
              "\r",
              "// Validate presence of required keys\r",
              "pm.test(\"Response contains required keys\", function () {\r",
              "    const expectedKeys = [\r",
              "        \"AAA\", \"sold\", \"5000\", \"6000\", \"string\", \"unavailable\", \"Busy\",\r",
              "        \"pending\", \"testing\", \"available\", \"active\", \"False\", \"0\", \"Sold\",\r",
              "        \"invalid_status\", \"QMock status\", \"avaliable\", \"Available\", \"Pending\"\r",
              "    ];\r",
              "    expectedKeys.forEach(key => {\r",
              "        pm.expect(jsonData).to.have.property(key);\r",
              "    });\r",
              "});\r",
              "\r",
              "// Validate data types (numeric vs string)\r",
              "pm.test(\"Numeric fields are numbers\", function () {\r",
              "    pm.expect(jsonData[\"AAA\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"sold\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"string\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"available\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"pending\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"unavailable\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"active\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"Busy\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"testing\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"invalid_status\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"0\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"Sold\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"QMock status\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"avaliable\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"Available\"]).to.be.a(\"number\");\r",
              "    pm.expect(jsonData[\"Pending\"]).to.be.a(\"number\");\r",
              "\r",
              "});\r",
              "\r",
              "// Validate specific values (example checks)\r",
              "pm.test(\"Sold count is within expected range\", function () {\r",
              "    pm.expect(jsonData[\"sold\"]).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Available count is not negative\", function () {\r",
              "    pm.expect(jsonData[\"available\"]).to.be.at.least(0);\r",
              "});\r",
              "\r",
              "// Optional: check spelling consistency\r",
              "pm.test(\"Check for inconsistent status spelling\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"available\");\r",
              "    pm.expect(jsonData).to.have.property(\"avaliable\"); // highlight mismatch\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "//json schema\r",
              "\r",
              "const schema = {\r",
              "    type: \"object\",\r",
              "    required: [\r",
              "        \"AAA\", \"sold\", \"5000\", \"6000\", \"string\", \"unavailable\", \"Busy\",\r",
              "        \"pending\", \"testing\", \"available\", \"active\", \"False\", \"0\", \"Sold\",\r",
              "        \"invalid_status\", \"QMock status\", \"avaliable\", \"Available\", \"Pending\"\r",
              "    ],\r",
              "    properties: {\r",
              "        AAA: { type: \"number\" },\r",
              "        sold: { type: \"number\" },\r",
              "        \"5000\": { type: \"number\" },\r",
              "        \"6000\": { type: \"number\" },\r",
              "        string: { type: \"number\" },\r",
              "        unavailable: { type: \"number\" },\r",
              "        Busy: { type: \"number\" },\r",
              "        pending: { type: \"number\" },\r",
              "        testing: { type: \"number\" },\r",
              "        available: { type: \"number\" },\r",
              "        active: { type: \"number\" },\r",
              "        False: { type: \"number\" },\r",
              "        \"0\": { type: \"number\" },\r",
              "        Sold: { type: \"number\" },\r",
              "        invalid_status: { type: \"number\" },\r",
              "        \"QMock status\": { type: \"number\" },\r",
              "        avaliable: { type: \"number\" },\r",
              "        Available: { type: \"number\" },\r",
              "        Pending: { type: \"number\" }\r",
              "    }\r",
              "};\r",
              "\r",
              "\r",
              "pm.test(\"Response matches JSON schema\", function () {\r",
              "    pm.expect(tv4.validate(jsonData, schema)).to.be.true;\r",
              "});\r",
